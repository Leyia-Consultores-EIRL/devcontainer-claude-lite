# Supply chain hardening (issue #40)
# Block install of package versions younger than this many minutes.
# 2880 = 48h. Most malicious packages get yanked within 24h of detection;
# 48h gives a wide safety margin. Cost: cannot install hot-off-the-press
# legitimate updates immediately — acceptable trade.
# Bump to 10080 (7 days) for high-stakes projects.
minimum-release-age=2880

# Always verify package integrity from registry signature.
# (pnpm 9+ default, but explicit for posterity.)
audit-signatures=true

# Fail loudly on audit findings during install, dont silent-pass.
# strict-peer-dependencies kept default (false) — many ecosystems still messy.
